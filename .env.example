TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_USER_ID=""

# Cron trigger (GitHub Actions → POST /cron/digest on Railway). Generate a random string.
CRON_SECRET=""
# Public Railway domain (e.g. my-app.up.railway.app). Synced to GitHub; on Railway set automatically.
RAILWAY_PUBLIC_DOMAIN=""
GEMINI_API_KEY=""

# OpenRouter (news via perplexity/sonar). https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# OPENROUTER_NEWS_MODEL=perplexity/sonar

# Langfuse Cloud (optional — LLM tracing). Leave empty to disable.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Railway CLI auth (project token). Local/devcontainer only — not synced to Railway.
# Railway → Project → Settings → Tokens → Generate Project Token
RAILWAY_TOKEN=""

# Webhook mode (Railway prod). Leave empty locally → polling.
WEBHOOK_URL=""
WEBHOOK_SECRET=""
# WEBHOOK_PATH=telegram
# RAILWAY_PUBLIC_DOMAIN is set by Railway; can be used instead of WEBHOOK_URL

