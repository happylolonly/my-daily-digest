{
  "name": "Daily Digest Bot",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "containerEnv": {
    "TZ": "Asia/Ho_Chi_Minh",
    "PIP_CACHE_DIR": "/home/vscode/.cache/pip",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  },
  "forwardAgent": true,
  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "initializeCommand": "test -f ${localWorkspaceFolder}/.env.railway || cp ${localWorkspaceFolder}/.env.railway.example ${localWorkspaceFolder}/.env.railway",
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env.railway"],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
    "source=daily-digest-claude-plugins,target=/home/vscode/.claude/plugins,type=volume",
    "source=daily-digest-pip-cache,target=/home/vscode/.cache/pip,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/stuartleeks/dev-container-features/railway-cli:0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.black-formatter",
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode"
}
